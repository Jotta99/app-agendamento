# ==========================================================
# Exemplo de variáveis de ambiente do servidor.
# Copie este arquivo para `.env` e preencha com valores reais.
# O arquivo `.env` NUNCA deve ser versionado (está no .gitignore).
# ==========================================================

# Ambiente: development | production | test
NODE_ENV=development

# Porta da API
PORT=3000

# URL do frontend autorizada no CORS
CORS_ORIGIN=http://localhost:5173

# ---------------------------
# Banco de dados (PostgreSQL)
# ---------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=troque_esta_senha
DB_DATABASE=app_agendamento
DB_TIMEZONE=America/Porto_Velho
# Cria/sincroniza as tabelas automaticamente a partir dos models.
# Em produção, prefira migrations e deixe DB_SYNC=false.
DB_SYNC=true

# ---------------------------
# Autenticação (JWT)
# Gere um segredo forte, ex.: openssl rand -base64 48
# ---------------------------
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio
JWT_EXPIRES_IN=1d

# ---------------------------
# Acesso único (a manicure). Definido apenas aqui — não há tabela de usuários.
# O login pede somente a senha.
# ---------------------------
AUTH_SENHA=troque_esta_senha_forte
