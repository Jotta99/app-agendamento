# ==========================================================
# Único arquivo de ambiente do projeto (API + front).
# Copie para `server/.env` e preencha com valores reais.
# O `.env` NUNCA deve ser versionado (está no .gitignore).
# O Vite (front) também lê este arquivo — veja VITE_API_URL no fim.
# ==========================================================

# Ambiente: development | production | test
NODE_ENV=development

# Porta da API
PORT=3000

# URL do frontend autorizada no CORS
CORS_ORIGIN=http://localhost:5173

# ---------------------------
# Banco de dados (PostgreSQL)
# ---------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=troque_esta_senha
DB_DATABASE=app_agendamento
DB_TIMEZONE=America/Porto_Velho
# Cria/sincroniza as tabelas automaticamente a partir dos models.
# Em produção, prefira migrations e deixe DB_SYNC=false.
DB_SYNC=true

# ---------------------------
# Autenticação (JWT)
# Gere um segredo forte, ex.: openssl rand -base64 48
# ---------------------------
JWT_SECRET=troque_por_um_segredo_longo_e_aleatorio
JWT_EXPIRES_IN=1d

# ---------------------------
# Acesso único (a manicure). Definido apenas aqui — não há tabela de usuários.
# O login pede somente a senha.
# ---------------------------
AUTH_SENHA=troque_esta_senha_forte

# ---------------------------
# Keep-alive (evita hibernação no Render): URL pública da API para auto-ping
# a cada 5 min em /api/health. No Render, a RENDER_EXTERNAL_URL já é injetada
# automaticamente, então isto é opcional. Em local, deixe vazio/sem definir.
# ---------------------------
# SELF_PING_URL=https://minha-api.onrender.com

# ---------------------------
# Frontend (Vite). Variáveis VITE_* ficam expostas no bundle público —
# NUNCA coloque segredos aqui. Deixe VAZIO: o front usa "/api" na mesma origem
# (a própria API serve o front; em dev o Vite faz proxy de /api -> :3000).
# Só preencha se o front estiver em um domínio diferente da API.
# ---------------------------
VITE_API_URL=
