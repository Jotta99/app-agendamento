# URL base da API. No frontend, variáveis VITE_* ficam expostas no bundle —
# NUNCA coloque segredos aqui (apenas configuração pública, como esta URL).
#
# Deixe VAZIO: o front usa "/api" na mesma origem (a própria API serve o front,
# e em dev o Vite faz proxy de /api -> localhost:3000). Só preencha se a API
# estiver em um domínio diferente do front.
VITE_API_URL=
