# URL base da API. No frontend, variáveis VITE_* ficam expostas no bundle —
# NUNCA coloque segredos aqui (apenas configuração pública, como esta URL).
#
# Deixe VAZIO para descobrir a API automaticamente pelo host atual (funciona em
# localhost e pelo IP da rede). Preencha apenas se a API estiver em outro lugar.
VITE_API_URL=
